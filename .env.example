PORT=8000
JWT_SECRET="your_secret_key"
REFRESH_TOKEN_SECRET="your_refresh_secret"
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# External URL (for webhooks/callbacks)
RENDER_EXTERNAL_URL=http://localhost:8000

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=replace_with_numeric_id
WHATSAPP_TOKEN=EAAG_replace_with_real_token

# Email Configuration (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Google OAuth
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

CONTROL_PLANE_KMS_KEY="your_32_byte_hex_encoded_key_here"

# Local PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/brewlabs_dev
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:password@localhost:5432/brewlabs_control_plane

# Tenant Database Configuration for New Cafe Onboarding (Local PostgreSQL)
DEFAULT_DB_HOST="localhost"
DEFAULT_DB_PORT=5432
DEFAULT_DB_USER="postgres"
DEFAULT_DB_PASSWORD="password"
DEFAULT_DB_NAME="postgres"

# ========================================
# DATA-FIRST ARCHITECTURE ENFORCEMENT
# ========================================

# STRICT_SCHEMA_MODE: When enabled (true), the system will BLOCK startup if:
#   - Model definition doesn't match database schema (new fields without migration)
#   - Fields removed from model but still exist in database
#   - Type mismatches between model and database
#   - Any schema inconsistency detected
# 
# DEV: Set to false to allow startup with warnings (default)
# PROD: Should ALWAYS be true to prevent data corruption
# 
# MANDATORY: When true, model changes MUST have corresponding migrations
STRICT_SCHEMA_MODE=false

# DATA_FIRST_STRICT: Legacy flag, also enables strict mode (kept for compatibility)
# DATA_FIRST_STRICT=false

# DATA_FIRST_LENIENT: Emergency escape hatch - allows startup despite blockers
# WARNING: Only use in emergencies, will cause data inconsistencies
# DATA_FIRST_LENIENT=false

# MIGRATION_LENIENT: Skip migration discipline checks (NOT recommended)
# MIGRATION_LENIENT=false