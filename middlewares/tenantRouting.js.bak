const tenantRoutingMiddleware = async (req, res, next) => {
  try {

    const auth = req.auth;

    if (!auth) {
      return next(createHttpError(401, "Authentication required"));
    }

    // SUPER ADMIN BYPASS
    if (auth.role === "SUPER_ADMIN") {
      return next();
    }

    if (auth.panelType !== "TENANT") {
      return next(createHttpError(403, "Tenant access required"));
    }

    const brandId = auth.businessId;

    if (!brandId) {
      return next(createHttpError(400, "Missing tenant identifier"));
    }

    console.log("🔍 Tenant Routing:", brandId);

    /*
    ------------------------------------
    STEP 1 — REDIS CACHE LOOKUP
    ------------------------------------
    */

    let conn = await getTenantConnection(brandId);

    if (!conn) {

      console.log("⚠️ Cache MISS → querying control plane");

      conn = await TenantConnection.findOne({
        where: { brandId }
      });

      if (!conn) {
        return next(createHttpError(503, "Tenant routing not configured"));
      }

      await cacheTenantConnection(brandId, conn.toJSON());
    } else {
      console.log("✅ Cache HIT for tenant", brandId);
    }

    if (!conn.migrated) {
      return next(createHttpError(503, "Tenant database not migrated"));
    }

    /*
    ------------------------------------
    STEP 2 — CREATE TENANT CONNECTION
    ------------------------------------
    */

    const tenantSequelize = await getTenantSequelize({
      brandId: conn.brandId,
      db_host: conn.db_host,
      db_port: conn.db_port,
      db_name: conn.db_name,
      db_user: conn.db_user,
      encrypted_password: conn.encrypted_password
    });

    if (!tenantSequelize) {
      throw new Error("Failed to initialize tenant connection");
    }

    /*
    ------------------------------------
    STEP 3 — INITIALIZE MODELS
    ------------------------------------
    */

    const tenantModels = await initializeTenantModels(tenantSequelize);

    if (!tenantModels) {
      throw new Error("Tenant models initialization failed");
    }

    /*
    ------------------------------------
    STEP 4 — ATTACH TO REQUEST
    ------------------------------------
    */

    req.tenantSequelize = tenantSequelize;
    req.tenantModels = tenantModels;
    req.businessId = conn.brandId; // Set businessId for repositories
    req.brandId = conn.brandId;    // Aliased for consistency
    
    // Fallback outletId if provided in token (common for store managers)
    req.outletId = auth.outletId || null;

    req.tenantMeta = {
      brandId: conn.brandId,
      clusterId: conn.cluster_id
    };

    console.log("✅ Tenant routing successful:", brandId);

    return next();

  } catch (err) {

    console.error("❌ Tenant Routing Error:", err.message);

    return next(
      createHttpError(503, "Tenant database unavailable")
    );

  }
};

// Validation: ensure export is a function
if (typeof tenantRoutingMiddleware !== "function") {
  throw new Error("tenantRoutingMiddleware export invalid");
}

module.exports = { tenantRoutingMiddleware };
