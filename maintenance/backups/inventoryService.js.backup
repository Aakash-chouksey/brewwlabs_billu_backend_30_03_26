const { Op } = require('sequelize');

class InventoryService {
    // Check if product can be prepared based on recipe
    static async canPrepareProduct(req, productId, quantity) {
        if (!req.models) {
            throw new Error('Model injection failed');
        }
        try {
            const { businessId, outletId } = req;
            const { Recipe, RecipeItem, InventoryItem } = req.models;
            const recipe = await Recipe.findOne({
                where: { productId, businessId, outletId, isActive: true },
                include: [{
                    model: RecipeItem,
                    as: 'recipeItems',
                    include: [{
                        model: InventoryItem,
                        as: 'inventoryItem',
                        attributes: ['id', 'name', 'unit', 'category', 'currentStock']
                    }]
                }]
            });

            if (!recipe) {
                return { canPrepare: true, message: "No recipe found for product" };
            }

            const unavailableIngredients = [];
            const availableIngredients = [];

            for (const recipeItem of recipe.recipeItems) {
                if (recipeItem.isOptional) {
                    availableIngredients.push({
                        ingredient: recipeItem.inventoryItem.name,
                        inventoryItemId: recipeItem.inventoryItem.id,
                        required: parseFloat(recipeItem.quantityRequired) * quantity,
                        available: parseFloat(recipeItem.inventoryItem.currentStock),
                        unit: recipeItem.unit,
                        isOptional: true
                    });
                    continue;
                }

                const requiredQuantity = parseFloat(recipeItem.quantityRequired) * quantity;
                const availableStock = parseFloat(recipeItem.inventoryItem.currentStock);

                if (availableStock < requiredQuantity) {
                    unavailableIngredients.push({
                        ingredient: recipeItem.inventoryItem.name,
                        inventoryItemId: recipeItem.inventoryItem.id,
                        required: requiredQuantity,
                        available: availableStock,
                        unit: recipeItem.unit,
                        shortage: requiredQuantity - availableStock
                    });
                } else {
                    availableIngredients.push({
                        ingredient: recipeItem.inventoryItem.name,
                        inventoryItemId: recipeItem.inventoryItem.id,
                        required: requiredQuantity,
                        available: availableStock,
                        unit: recipeItem.unit,
                        isOptional: false
                    });
                }
            }

            return {
                canPrepare: unavailableIngredients.length === 0,
                recipe: recipe.name,
                availableIngredients,
                unavailableIngredients,
                message: unavailableIngredients.length === 0 
                    ? `Can prepare ${quantity} units`
                    : `Insufficient ingredients to prepare ${quantity} units`
            };
        } catch (error) {
            throw new Error(`Error checking product availability: ${error.message}`);
        }
    }

    // Deduct inventory when product is sold
    static async deductInventoryForSale(req, productId, quantity, orderId) {
        if (!req.models) {
            throw new Error('Model injection failed');
        }
        try {
            const { businessId, outletId } = req;
            const { Recipe, RecipeItem, InventoryItem, InventoryTransaction } = req.models;
            const recipe = await Recipe.findOne({
                where: { productId, businessId, outletId, isActive: true },
                include: [{
                    model: RecipeItem,
                    as: 'recipeItems',
                    include: [{
                        model: InventoryItem,
                        as: 'inventoryItem'
                    }]
                }]
            });

            if (!recipe) {
                return { success: false, message: "No recipe found for product" };
            }

            const transaction = await req.sequelize.transaction();
            try {
                for (const recipeItem of recipe.recipeItems) {
                    if (recipeItem.isOptional) continue;

                    const requiredQuantity = parseFloat(recipeItem.quantityRequired) * quantity;
                    const inventoryItem = recipeItem.inventoryItem;
                    const currentStock = parseFloat(inventoryItem.currentStock);

                    if (currentStock < requiredQuantity) {
                        throw new Error(`Insufficient stock for ${inventoryItem.name}. Required: ${requiredQuantity}, Available: ${currentStock}`);
                    }

                    const newStock = currentStock - requiredQuantity;
                    await inventoryItem.update({ currentStock: newStock }, { transaction });

                    await InventoryTransaction.create({
                        inventoryItemId: inventoryItem.id,
                        transactionType: 'SELL',
                        quantity: requiredQuantity,
                        previousStock: currentStock,
                        newStock,
                        referenceNumber: orderId,
                        reason: `Sale of ${recipe.name}`,
                        businessId,
                        outletId,
                        createdBy: req.user?.id || req.auth?.id
                    }, { transaction });
                }

                await transaction.commit();
                return { success: true, message: "Inventory deducted successfully" };
            } catch (error) {
                await transaction.rollback();
                throw error;

                deductionResults.push({
                    ingredient: inventoryItem.name,
                    quantityDeducted: requiredQuantity,
                    previousStock,
                    newStock,
                    transactionId: transaction.id
                });
            }

            if (errors.length > 0) {
                return {
                    success: false,
                    message: "Some ingredients could not be deducted",
                    errors,
                    deductionResults
                };
            }

            return {
                success: true,
                message: `Successfully deducted inventory for ${quantity} x ${recipe.name}`,
                deductionResults
            };
        } catch (error) {
            throw new Error(`Error deducting inventory: ${error.message}`);
        }
    }

    // Bulk check for multiple products in an order
    static async checkOrderAvailability(req, orderItems) {
        if (!req.models) {
            throw new Error('Model injection failed');
        }
        try {
            const { businessId, outletId } = req;
            const results = [];
            let canPrepareAll = true;

            for (const orderItem of orderItems) {
                const { productId, quantity } = orderItem;
                const availability = await this.canPrepareProduct(req, productId, quantity);
                
                results.push({
                    productId,
                    quantity,
                    ...availability
                });

                if (!availability.canPrepare) {
                    canPrepareAll = false;
                }
            }

            return {
                canPrepareAll,
                results,
                message: canPrepareAll 
                    ? "All products can be prepared"
                    : "Some products cannot be prepared due to insufficient ingredients"
            };
        } catch (error) {
        }

        if (errors.length > 0) {
            return {
                success: false,
                message: "Some items could not be deducted",
                errors,
                deductionResults
            };
        }

        return {
            success: true,
            message: "Successfully deducted inventory for order",
            deductionResults
        };
    } catch (error) {
        throw new Error(`Error deducting inventory for order: ${error.message}`);
    }
}

// Get inventory consumption report
static async getConsumptionReport(models, businessId, outletId, startDate, endDate) {
    try {
        const { InventoryTransaction, InventoryItem } = models;
        let whereClause = {
            businessId,
            outletId,
            type: 'SELL'
        };

        if (startDate || endDate) {
            whereClause.createdAt = {};
            if (startDate) whereClause.createdAt[Op.gte] = new Date(startDate);
            if (endDate) whereClause.createdAt[Op.lte] = new Date(endDate);
        }

        const transactions = await InventoryTransaction.findAll({
            where: whereClause,
            include: [{
                model: InventoryItem,
                as: 'inventoryItem',
                attributes: ['id', 'name', 'unit', 'category']
            }],
            order: [['createdAt', 'DESC']]
        });

        // Group by ingredient
        const consumptionByIngredient = {};
        
        transactions.forEach(transaction => {
            const ingredient = transaction.inventoryItem.name;
            const category = transaction.inventoryItem.category;
            
            if (!consumptionByIngredient[ingredient]) {
                consumptionByIngredient[ingredient] = {
                    name: ingredient,
                    category,
                    unit: transaction.inventoryItem.unit,
                    totalQuantity: 0,
                    transactionCount: 0,
                    transactions: []
                };
            }
            
            consumptionByIngredient[ingredient].totalQuantity += parseFloat(transaction.quantity);
            consumptionByIngredient[ingredient].transactionCount += 1;
            consumptionByIngredient[ingredient].transactions.push({
                date: transaction.createdAt,
                quantity: parseFloat(transaction.quantity),
                reference: transaction.reference,
                note: transaction.note
            });
        });

        return {
            success: true,
            data: {
                period: { startDate, endDate },
                totalTransactions: transactions.length,
                consumptionByIngredient: Object.values(consumptionByIngredient)
            }
        };
    } catch (error) {
        throw new Error(`Error generating consumption report: ${error.message}`);
    }
}

// Get low stock alerts
static async getLowStockAlerts(models, businessId, outletId) {
    try {
        const { InventoryItem } = models;
        const lowStockItems = await InventoryItem.findAll({
            where: {
            const { InventoryTransaction, InventoryItem } = models;
            let whereClause = {
                businessId,
                outletId,
                type: 'SELL'
            };

            if (startDate || endDate) {
                whereClause.createdAt = {};
                if (startDate) whereClause.createdAt[Op.gte] = new Date(startDate);
                if (endDate) whereClause.createdAt[Op.lte] = new Date(endDate);
            }

            const transactions = await InventoryTransaction.findAll({
                where: whereClause,
                include: [{
                    model: InventoryItem,
                    as: 'inventoryItem',
                    attributes: ['id', 'name', 'unit', 'category']
                }],
                order: [['createdAt', 'DESC']]
            });

            // Group by ingredient
            const consumptionByIngredient = {};
            
            transactions.forEach(transaction => {
                const ingredient = transaction.inventoryItem.name;
                const category = transaction.inventoryItem.category;
                
                if (!consumptionByIngredient[ingredient]) {
                    consumptionByIngredient[ingredient] = {
                        name: ingredient,
                        category,
                        unit: transaction.inventoryItem.unit,
                        totalQuantity: 0,
                        transactionCount: 0,
                        transactions: []
                    };
                }
                
                consumptionByIngredient[ingredient].totalQuantity += parseFloat(transaction.quantity);
                consumptionByIngredient[ingredient].transactionCount += 1;
                consumptionByIngredient[ingredient].transactions.push({
                    date: transaction.createdAt,
                    quantity: parseFloat(transaction.quantity),
                    reference: transaction.reference,
                    note: transaction.note
                });
            });

            return {
                success: true,
                data: {
                    period: { startDate, endDate },
                    totalTransactions: transactions.length,
                    consumptionByIngredient: Object.values(consumptionByIngredient)
                }
            };
        } catch (error) {
            throw new Error(`Error generating consumption report: ${error.message}`);
        }
    }

    // Get low stock alerts
    static async getLowStockAlerts(models, businessId, outletId) {
        try {
            const { InventoryItem } = models;
            const lowStockItems = await InventoryItem.findAll({
                where: {
                    businessId,
                    outletId,
                    isActive: true,
                    currentStock: { [Op.lte]: InventoryItem.sequelize.col('minimum_stock_level') }
                },
                order: [['name', 'ASC']]
            });

            const alerts = lowStockItems.map(item => ({
                id: item.id,
                name: item.name,
                category: item.category,
                currentStock: parseFloat(item.currentStock),
                minimumStockLevel: parseFloat(item.minimumStockLevel),
                unit: item.unit,
                shortage: parseFloat(item.minimumStockLevel) - parseFloat(item.currentStock),
                urgency: this.getUrgencyLevel(item.currentStock, item.minimumStockLevel),
                lastRestockedAt: item.lastRestockedAt
            }));

            return {
                success: true,
                data: {
                    totalAlerts: alerts.length,
                    alerts
                }
            };
        } catch (error) {
            throw new Error(`Error getting low stock alerts: ${error.message}`);
        }
    }

    // Helper method to determine urgency level
    static getUrgencyLevel(currentStock, minimumStockLevel) {
        const current = parseFloat(currentStock);
        const minimum = parseFloat(minimumStockLevel);
        const ratio = current / minimum;

        if (ratio <= 0) return 'OUT_OF_STOCK';
        if (ratio <= 0.25) return 'CRITICAL';
        if (ratio <= 0.5) return 'HIGH';
        if (ratio <= 0.75) return 'MEDIUM';
        return 'LOW';
    }

    // Get inventory value report
    static async getInventoryValueReport(models, businessId, outletId) {
        try {
            const { InventoryItem } = models;
            const inventoryItems = await InventoryItem.findAll({
                where: { businessId, outletId, isActive: true }
            });

            let totalValue = 0;
            let totalItems = 0;
            const categoryBreakdown = {};

            inventoryItems.forEach(item => {
                const itemValue = parseFloat(item.currentStock) * parseFloat(item.costPerUnit);
                const category = item.category;

                totalValue += itemValue;
                totalItems += parseFloat(item.currentStock);

                if (!categoryBreakdown[category]) {
                    categoryBreakdown[category] = {
                        category,
                        totalValue: 0,
                        totalItems: 0,
                        itemCount: 0
                    };
                }

                categoryBreakdown[category].totalValue += itemValue;
                categoryBreakdown[category].totalItems += parseFloat(item.currentStock);
                categoryBreakdown[category].itemCount += 1;
            });

            return {
                success: true,
                data: {
                    totalValue,
                    totalItems,
                    categoryBreakdown: Object.values(categoryBreakdown),
                    summary: {
                        totalSKUs: inventoryItems.length,
                        averageValuePerItem: totalItems > 0 ? totalValue / totalItems : 0,
                        averageStockPerSKU: inventoryItems.length > 0 ? totalItems / inventoryItems.length : 0
                    }
                }
            };
        } catch (error) {
            throw new Error(`Error generating inventory value report: ${error.message}`);
        }
    }
}

module.exports = InventoryService;
