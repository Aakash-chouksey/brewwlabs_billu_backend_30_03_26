			"value": "2026-03-20",
			"type": "string"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set current date automatically",
					"const today = new Date().toISOString().split('T')[0];",
					"pm.collectionVariables.set('current_date', today);",
					"",
					"// Set date range for last 7 days",
					"const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];",
					"pm.collectionVariables.set('start_date', weekAgo);",
					"pm.collectionVariables.set('end_date', today);",
					"",
					"console.log('Current date set to:', today);",
					"console.log('Date range set to:', weekAgo, 'to', today);"
				]
			}
		}
	],
