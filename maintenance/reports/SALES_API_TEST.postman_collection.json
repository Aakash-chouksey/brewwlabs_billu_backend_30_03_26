	"item": [
		{
			"name": "Sales Dashboard",
			"item": [
				{
					"name": "Get Sales Dashboard",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has success field\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('success');",
									"});",
									"",
									"pm.test(\"Success is true\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"pm.test(\"Response has required fields\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('data');",
									"    if (jsonData.data) {",
									"        pm.expect(jsonData.data).to.have.property('revenueToday');",
									"        pm.expect(jsonData.data).to.have.property('ordersToday');",
									"        pm.expect(jsonData.data).to.have.property('topProduct');",
									"    }",
									"});",
									"",
									"console.log('Sales Dashboard Response:', pm.response.json());"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/tenant/sales/dashboard",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "tenant", "sales", "dashboard"]
						},
						"description": "Get sales dashboard with today's revenue, orders, and weekly stats"
					},
					"response": []
				},
