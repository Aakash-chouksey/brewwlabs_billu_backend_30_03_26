        },
        "url": {
          "raw": "{{BASE_URL}}/api/admin/login",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "admin", "login"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200 && pm.response.json().success) {",
              "    pm.variables.set('SUPER_ADMIN_TOKEN', pm.response.json().data.accessToken);",
              "    console.log('✅ Token saved: ' + pm.variables.get('SUPER_ADMIN_TOKEN').substring(0, 20) + '...');",
              "}"
            ]
          }
        }
