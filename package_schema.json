{
  "name": "pos-backend-schema-per-tenant",
  "version": "2.0.0",
  "description": "POS Backend with Schema-per-Tenant Multi-Tenancy Architecture",
  "main": "app_schema.js",
  "scripts": {
    "start": "node app_schema.js",
    "dev": "nodemon app_schema.js",
    "migrate-to-schema": "node scripts/migrateToSchemaPerTenant.js",
    "migrate-dry-run": "node scripts/migrateToSchemaPerTenant.js --dry-run",
    "safety-report": "node scripts/generateSafetyReport.js",
    "validate-schema": "node scripts/validateSchemaIsolation.js",
    "test-tenant": "node scripts/testTenantIsolation.js",
    "cache-stats": "node scripts/cacheStatistics.js",
    "emergency-reset": "node scripts/emergencyReset.js",
    "health-check": "curl -f http://localhost:8000/health || exit 1",
    "postinstall": "echo '🏗️ Schema-per-Tenant POS Backend installed successfully'"
  },
  "keywords": [
    "pos",
    "multi-tenant",
    "schema-per-tenant",
    "postgresql",
    "neon",
    "nodejs",
    "express"
  ],
  "author": "Breww Labs",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "sequelize": "^6.35.2",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "axios": "^1.6.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "nodemailer": "^6.9.7",
    "cron": "^3.1.6",
    "bull": "^4.12.2",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.10.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brewwlabs/pos-backend-schema-per-tenant.git"
  },
  "bugs": {
    "url": "https://github.com/brewwlabs/pos-backend-schema-per-tenant/issues"
  },
  "homepage": "https://github.com/brewwlabs/pos-backend-schema-per-tenant#readme"
}
