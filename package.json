{
  "name": "pos-backend",
  "version": "1.0.0",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon --inspect=0.0.0.0:9229 --exec 'npm run start'",
    "start": "node app.js",
    "start:parallel": "node scripts/start-parallel.js",
    "start:prod": "node render-deploy.js",
    "render-start": "node render-deploy.js",
    "dev:parallel": "nodemon --inspect=0.0.0.0:9229 --exec 'node --max-old-space-size=4096 app.js'",
    "dev:watch": "nodemon --watch src --watch models --watch middlewares --watch services --watch routes --ext js,json --exec 'npm run start'",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:regression": "jest tests/regression --forceExit",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "test:security": "jest tests/security --forceExit",
    "migrate:control-plane": "node scripts/initialize_control_plane.js",
    "migrate:tenant": "node scripts/migrateTenant.js",
    "seed:control-plane": "node scripts/seedControlPlane.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "df:init": "node scripts/data-first-cli.js init",
    "df:status": "node scripts/data-first-cli.js status",
    "df:health": "node scripts/data-first-cli.js health",
    "df:validate-schema": "node scripts/data-first-cli.js validate-schema",
    "df:validate-deploy": "node scripts/data-first-cli.js validate-deploy",
    "df:check-migrations": "node scripts/data-first-cli.js check-migrations",
    "test:automation": "node tests/automation/runTests.js",
    "test:automation:fix": "AUTO_FIX=true node tests/automation/runTests.js",
    "test:reset": "node scripts/reset-system.js --force",
    "test:reset:dry": "node scripts/reset-system.js",
    "test:onboarding": "SKIP_RESET=true SKIP_API=true node tests/automation/runTests.js",
    "test:db": "SKIP_RESET=true SKIP_ONBOARDING=true SKIP_API=true node tests/automation/runTests.js",
    "clear-model-cache": "node scripts/clear-model-cache.js",
    "validate:system": "node scripts/validate-system.js",
    "validate:fix": "AUTO_FIX=true node scripts/validate-system.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Backend test configuration",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.991.0",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cls-hooked": "^4.2.2",
    "colors": "^1.4.0",
    "compression": "^1.8.1",
    "continuation-local-storage": "^3.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csv-parser": "^3.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.5",
    "redis": "^5.11.0",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/scripts/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ]
  }
}
